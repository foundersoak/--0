# ---------------------------------------------------------------------------
# blankand0 environment variables
# Copy to .env.local for local dev, or set these in the Vercel project settings.
# Nothing here is required to build or play — only the global leaderboard needs it.
# ---------------------------------------------------------------------------

# Global leaderboard storage — Vercel KV / Upstash Redis (REST API).
# OPTIONAL: without these, the leaderboard still works but uses an in-memory
# store that resets on every serverless cold start (i.e. not a real global board).
# In the Vercel dashboard: Storage -> create a Redis store and connect it to this
# project; credentials are injected automatically. The leaderboard works with any
# of these (checked in this order):
#   1. KV_REST_API_URL + KV_REST_API_TOKEN     (Upstash REST API)
#   2. UPSTASH_REDIS_REST_URL + _TOKEN          (Upstash REST API, alt names)
#   3. REDIS_URL                                (standard Redis connection string)
# Copy whichever your store provides here for local development.
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=

# ---------------------------------------------------------------------------
# Contact form delivery — set up EITHER Resend OR Formspree (only one needed).
# The destination inbox lives here as a server secret; it is never shown on the site.
# ---------------------------------------------------------------------------
# Resend (https://resend.com): an API key + the inbox that receives messages.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=            # a verified Resend sender (defaults to onboarding@resend.dev)
# Formspree (https://formspree.io): the full form endpoint, e.g. https://formspree.io/f/abcwxyz
FORMSPREE_ENDPOINT=
